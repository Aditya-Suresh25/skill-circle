rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && request.resource.data.created_by == request.auth.uid;
    }

    match /SkillCircles/{circleId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.created_by == request.auth.uid
        && request.resource.data.circle_name is string
        && request.resource.data.description is string;
      allow update: if signedIn(); // Allow members to join/leave or creator to edit
      allow delete: if signedIn() && resource.data.created_by == request.auth.uid;
      
      match /channels/{channelId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update: if signedIn(); // For typing status
        
        match /messages/{messageId} {
          allow read: if signedIn();
          allow create: if signedIn();
          allow update: if signedIn(); // For readBy updates
        }
      }
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }
    
    // Posts
    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid && request.resource.data.post_content is string && request.resource.data.circle_id is string;
      allow update, delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    // Post votes
    match /postVotes/{voteId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid && request.resource.data.post_id is string;
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    // Comments
    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid && request.resource.data.post_id is string && request.resource.data.comment_text is string;
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }
  }
}